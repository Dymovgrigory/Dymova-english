# --- MAX Bot API ---
# Токен бота: платформа MAX → Чат-боты → Перейти → Расширенные настройки → Настроить
MAX_BOT_TOKEN=
# botapi.max.ru работает без доп. сертификатов. Новый домен platform-api2.max.ru
# требует корневой сертификат Минцифры на хосте (миграция до 19.07.2026).
MAX_BOT_API_URL=https://botapi.max.ru
# Произвольный секрет; если задан, проверяется в заголовке X-Max-Bot-Api-Secret
MAX_WEBHOOK_SECRET=

# --- LLM (бесплатный, OpenAI-совместимый) ---
# По умолчанию OpenRouter + бесплатная модель. Ключ создаётся бесплатно на
# https://openrouter.ai/keys . Можно заменить на Groq / локальный Ollama и т.п.
# Если используете OpenAI, задайте:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_FALLBACKS=[{"base_url":"https://api.openai.com/v1","api_key":"sk-...","model":"gpt-4o-mini"}]
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_FALLBACKS=[]
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=700

# --- BigBen CRM (интеграция с сайтом через API) ---
# URL запроса и ключ: CRM → Управление школой → Настройки школы → Интеграции →
# Работа с API → Сгенерировать. pipeline_id / pipeline_status_id — воронка и этап.
BIGBEN_API_URL=https://panel.bigbencrm.ru/api/leads/add
BIGBEN_API_KEY=
BIGBEN_PIPELINE_ID=1924
BIGBEN_PIPELINE_STATUS_ID=1

# --- Observability / notifications ---
# SENTRY_DSN=https://...
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.0
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Передача администратору ---
# ID администраторов в MAX через запятую (куда дублируется контекст диалога)
ADMIN_MAX_IDS=

# --- Мини-приложение ---
# Публичный URL мини-приложения (личный кабинет/витрина), напр. https://host/app/
MINIAPP_BASE_URL=
# Если true, miniapp будет считать профиль незарегистрированным, пока в MAX нет
# completed registration для этого user_id.
MINIAPP_REQUIRE_REGISTRATION=true

# --- Цикл улучшения: журнал вопросов без ответа и ежедневный отчёт ---
# INSIGHTS_FILE=./data/insights.jsonl  # JSONL-журнал вопросов без уверенного ответа
# DIGEST_ENABLED=true                  # ежедневный дайджест администраторам
# DIGEST_HOUR=21                       # час отправки (по DIGEST_TZ_OFFSET)
# DIGEST_MINUTE=0
# DIGEST_TZ_OFFSET=3                   # МСК
# DIGEST_DAYS=1                        # период отчёта в днях
# NUDGE_ENABLED=true                   # тёплые напоминания незавершённым заявкам
# NUDGE_HOUR=11
# NUDGE_MINUTE=0

# --- Живая синхронизация KB с сайтом ---
# SITE_SYNC_ENABLED=true               # подтягивать актуальный контент сайта в базу знаний
# SITE_SYNC_URLS=                      # URL через запятую; пусто = https://dymova-english.ru
# SITE_SYNC_INTERVAL_MIN=60            # период обновления в минутах

# --- Прочее ---
# DB_PATH=./data/bot.db  # путь для персистентности диалогов между перезапусками
# STATE_FILE=             # legacy alias для DB_PATH
