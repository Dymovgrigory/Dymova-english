# --- MAX Bot API ---
# Токен бота: платформа MAX → Чат-боты → Перейти → Расширенные настройки → Настроить
MAX_BOT_TOKEN=
# botapi.max.ru работает без доп. сертификатов. Новый домен platform-api2.max.ru
# требует корневой сертификат Минцифры на хосте (миграция до 19.07.2026).
MAX_BOT_API_URL=https://botapi.max.ru
# Произвольный секрет; если задан, проверяется в заголовке X-Max-Bot-Api-Secret
MAX_WEBHOOK_SECRET=

# --- LLM (OpenAI-совместимый, с каскадом провайдеров) ---
# РЕКОМЕНДАЦИЯ (оплата из РФ, рублями): ProxyAPI.ru — прокси к OpenAI, даёт
# gpt-4o-mini. Ключ и баланс: https://proxyapi.ru . Пример:
#   LLM_API_KEY=<ключ ProxyAPI>
#   LLM_BASE_URL=https://api.proxyapi.ru/openai/v1
#   LLM_MODEL=gpt-4o-mini
# В каскад запасных можно добавить бесплатную модель OpenRouter (ключ бесплатно
# на https://openrouter.ai/keys), чтобы бот не падал при сбое основного:
#   LLM_FALLBACKS=[{"base_url":"https://openrouter.ai/api/v1","api_key":"<ключ OpenRouter>","model":"meta-llama/llama-3.3-70b-instruct:free"}]
# Прямой OpenAI (нужен зарубежный биллинг): LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_BASE_URL=https://api.proxyapi.ru/openai/v1
LLM_MODEL=gpt-4o-mini
LLM_FALLBACKS=[]
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=700

# --- BigBen CRM (интеграция с сайтом через API) ---
# URL запроса и ключ: CRM → Управление школой → Настройки школы → Интеграции →
# Работа с API → Сгенерировать. pipeline_id / pipeline_status_id — воронка и этап.
BIGBEN_API_URL=
BIGBEN_API_KEY=
BIGBEN_PIPELINE_ID=
BIGBEN_PIPELINE_STATUS_ID=

# --- Передача администратору ---
# ID администраторов в MAX через запятую (куда дублируется контекст диалога)
ADMIN_MAX_IDS=

# --- Мини-приложение ---
# Публичный URL мини-приложения (личный кабинет/витрина), напр. https://host/app/
MINIAPP_BASE_URL=

# --- Прочее ---
# DB_PATH=./data/bot.db  # путь для персистентности диалогов между перезапусками
# STATE_FILE=             # legacy alias для DB_PATH
