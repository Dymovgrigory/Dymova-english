# --- MAX Bot API ---
# Токен бота: платформа MAX → Чат-боты → Перейти → Расширенные настройки → Настроить
MAX_BOT_TOKEN=
# botapi.max.ru работает без доп. сертификатов. Новый домен platform-api2.max.ru
# требует корневой сертификат Минцифры на хосте (миграция до 19.07.2026).
MAX_BOT_API_URL=https://botapi.max.ru
# Произвольный секрет; если задан, проверяется в заголовке X-Max-Bot-Api-Secret
MAX_WEBHOOK_SECRET=

# --- LLM (провайдер-агностик, OpenAI-совместимый) ---
# Рекомендуется ProxyAPI.ru как основной провайдер для РФ:
#   LLM_BASE_URL=https://api.proxyapi.ru/openai/v1
#   LLM_MODEL=gpt-4o-mini
# Затем можно добавить каскад через OpenRouter:
#   LLM_FALLBACKS=[{"base_url":"https://openrouter.ai/api/v1","api_key":"sk-or-...","model":"meta-llama/llama-3.3-70b-instruct:free"}]
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_FALLBACKS=[]
VISION_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=700

# --- BigBen CRM (интеграция с сайтом через API) ---
# Эндпоинт GET-запроса (общий для всех школ BigBen) — можно не менять.
BIGBEN_API_URL=https://panel.bigbencrm.ru/api/leads/add
# Ключ (СЕКРЕТ): CRM → Управление школой → Настройки школы → Интеграции →
# Работа с API → Сгенерировать. Не публиковать в открытом виде.
BIGBEN_API_KEY=
# Воронка «Бот Макс» = 1924, этап «Входящие» = 1 (куда падают заявки бота).
# Другие этапы воронки 1924: Успешно=5, Отказ=6.
BIGBEN_PIPELINE_ID=1924
BIGBEN_PIPELINE_STATUS_ID=1
# Атрибуция заявок: бот проставляет source (канал + курс), UTM-метки и подробный
# user_note (резюме диалога, выбранный курс/филиал/возраст). UTM можно задавать
# через deep-link «/start utm_source=vk&utm_campaign=spring» или ?startapp=… в
# мини-приложении; короткий токен («/start vk») трактуется как utm_source.

# --- Администраторы бота ---
# Конкретные пользователи MAX (user_id через запятую). Им дублируется контекст
# переданных диалогов и ежедневный отчёт; в чате с ботом им доступны команды
# «/отчёт» (дайджест) и «/myid». Узнать свой ID: написать боту «/myid».
ADMIN_MAX_IDS=

# --- Ежедневный отчёт администраторам ---
DIGEST_ENABLED=true
DIGEST_HOUR=21        # час отправки в часовом поясе DIGEST_TZ_OFFSET
DIGEST_MINUTE=0
DIGEST_TZ_OFFSET=3    # Москва = +3 от UTC
DIGEST_DAYS=1         # период, за который собирается дайджест

# --- Мини-приложение ---
# Публичный URL мини-приложения (личный кабинет/витрина), напр. https://host/app/
MINIAPP_BASE_URL=

# --- Прочее ---
# STATE_FILE=/data/state.json  # путь для персистентности диалогов между перезапусками
# DEDUP_FILE=/data/dedup.db      # файл дедупликации webhook-ивентов (опционально)

# --- Цикл улучшения ---
# Журнал «пробелов»: вопросы, на которые бот ответил неуверенно. Если путь задан —
# отчёт доступен на GET /admin/insights и дайджест на GET /admin/insights/digest.
# INSIGHTS_FILE=/data/insights.jsonl
# Порог релевантности базы знаний (ниже — фиксируем пробел). По умолчанию 0.34.
# INSIGHTS_MIN_SCORE=0.34
# Токен для служебных эндпоинтов /admin/* (заголовок X-Admin-Token). Рекомендуется на проде.
# ADMIN_TOKEN=
